---
const metrics = [['50+','businesses served'],['100+','AI projects shipped'],['12+ yrs','AI & data science']];
---
<section class="grid grid-cols-1 sm:grid-cols-3 gap-4 py-8 border-y border-line">
  {metrics.map(([n,l]) => (
    <div>
      <div class="font-serif text-3xl">{n}</div>
      <div class="text-muted text-sm mt-1">{l}</div>
    </div>
  ))}
</section>
