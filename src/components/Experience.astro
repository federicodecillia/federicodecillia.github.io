---
const roles = [
  ['Lead Data Scientist, Global Retail & DTC Assortment Intelligence', 'EssilorLuxottica', 'Feb 2021 – present', 'I lead the data science unit for Global Retail & DTC Assortment Intelligence, optimizing assortment strategies across 18,000+ retail stores. I own the full lifecycle of AI initiatives, from ideation and prototyping to full-scale production deployment: forecasting engines, anomaly detection and clustering that drive automated decision-making at scale. I mentor a high-performing team, set Data and MLOps best practices, lead internal AI enablement (talks, training, hands-on sessions), and have delivered measurable business impact: license savings, multi-FTE efficiency gains and incremental revenue.'],
  ['AI Consultant & Trainer', 'Freelance', '2019 – present', 'I help teams and non-technical professionals actually use AI well, and I ship production-grade solutions: AI agents, LLM chatbots, automations and internal tools deployed for dozens of businesses across industries. Tailored AI training on generative AI, LLMs, agents and automation, from beginners to technical teams; advisory to spot high-impact use cases and avoid common implementation traps; end-to-end delivery from use-case scoping to production rollout. Recognized as a Vetted Pro on Fiverr (5/5 across 100+ projects).'],
  ['Senior Data Scientist', 'Nielsen', 'Sep 2017 – Feb 2021', 'Led predictive models (time series, classification, clustering) on audience and panel data across 40+ countries, and built scalable data pipelines.'],
  ['Data Scientist, Consultant', 'Bip — Business Integration Partners', 'Apr 2016 – Sep 2017', 'Big Data & Advanced Analytics CoE: delivered an NLP churn-prediction system and text-mining for customer profiling.'],
  ['Data Science Consultant', 'SAS / Value Lab', 'Jun 2015 – Apr 2016', 'SAS Masterclass in Big Data & Analytics; built ETL pipelines and BI dashboards.'],
  ['Data Mining Junior Officer, Marketing Department', 'Università Bocconi, Milan', 'Jan 2015 – Jun 2015', 'Supported the Marketing Department with data mining and analysis (SAP-CRM, STATA), generating insights and reporting on customer satisfaction to support strategic decision-making.'],
];
---
<section id="experience" class="py-12 scroll-mt-20 border-t border-line">
  <h2 class="font-serif text-3xl mb-6">Experience</h2>
  <div class="space-y-6">
    {roles.map(([title, org, dates, desc]) => (
      <div>
        <div class="flex flex-wrap items-baseline justify-between gap-x-4">
          <h3 class="font-medium">{title} <span class="text-muted font-normal">· {org}</span></h3>
          <span class="text-muted text-sm font-mono shrink-0">{dates}</span>
        </div>
        <p class="text-muted text-sm mt-1 leading-relaxed max-w-2xl">{desc}</p>
      </div>
    ))}
  </div>
</section>
