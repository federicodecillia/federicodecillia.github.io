---
const education = [
  ['Master in Statistical Sciences', 'University of Padua', '2012 — 2014'],
  ['LLP Erasmus, Economics', 'Universitat Pompeu Fabra, Barcelona', '2012'],
  ['Bachelor in Statistical Sciences', 'University of Padua', '2008 — 2011'],
];
const certs = [
  'Microsoft Azure Data Scientist Associate (DP-100)',
  'Databricks (certified)',
  'Deep Learning Specialization — deeplearning.ai',
  'Nova 111 Top Talent Italy (2023)',
];
---
<section id="education" class="py-12 scroll-mt-20 border-t border-line">
  <h2 class="font-serif text-3xl mb-6">Education & certifications</h2>
  <div class="grid sm:grid-cols-2 gap-8">
    <div class="space-y-5">
      {education.map(([degree, org, yr]) => (
        <div>
          <h3 class="font-medium">{degree}</h3>
          <p class="text-muted text-sm mt-1">{org} · <span class="font-mono">{yr}</span></p>
        </div>
      ))}
    </div>
    <ul class="space-y-2 text-muted text-sm">
      {certs.map((c) => <li class="flex gap-2"><span class="text-clay" aria-hidden="true">·</span>{c}</li>)}
    </ul>
  </div>
</section>
